rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, role, location, createdAt
    //
    // Collection: safetyPlans
    // Fields: uid, warningSigns, copingStrategies, socialContacts, professionalSupport, safeEnvironment, updatedAt
    //
    // Collection: stopSmokingLogs
    // Fields: uid, intensity, nrtUsed, timestamp
    //
    // Collection: checkins

    // Fields: uid, mood, craving, timestamp
    //
    // Collection: welfareChecks
    // Fields: uid, location, timestamp, notes
    //
    // Collection: messages
    // Fields: text, senderId, senderName, channel, timestamp
    //
    // Collection: journals
    // Fields: uid, text, shared, createdAt, wordCount
    //
    // Collection: breathworkSessions
    // Fields: uid, technique, cycles, timestamp
    //
    // Collection: groundingSessions
    // Fields: uid, timestamp, responses
    //
    // Collection: cbtRecords
    // Fields: uid, situation, automaticThought, emotion, evidence, balancedThought, status, updatedAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "GlennMercier15@gmail.com" && request.auth.token.email_verified == true));
    }

    function isStaff() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'outreach']);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['client', 'outreach', 'admin'];
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'senderId', 'senderName', 'channel', 'timestamp']) &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.senderId is string && data.senderId == request.auth.uid &&
             data.senderName is string && data.senderName.size() > 0 && data.senderName.size() <= 50 &&
             data.channel is string && data.channel.size() > 0 && data.channel.size() <= 50 &&
             data.timestamp == request.time;
    }

    function isValidJournalEntry(data) {
      return data.keys().hasAll(['uid', 'text', 'shared', 'createdAt']) &&
             data.uid is string &&
             data.text is string &&
             data.text.size() < 10000 &&
             data.shared is bool &&
             data.createdAt is string;
    }

    function isValidBreathworkSession(data) {
      return data.keys().hasAll(['uid', 'technique', 'cycles', 'timestamp']) &&
             data.uid is string &&
             data.technique in ['box', '478'] &&
             data.cycles is number &&
             data.timestamp is string;
    }

    function isValidGroundingSession(data) {
      return data.keys().hasAll(['uid', 'timestamp', 'responses']) &&
             data.uid is string &&
             data.timestamp is string &&
             data.responses is map;
    }

    function isValidCBTRecord(data) {
      return data.keys().hasAll(['uid', 'status', 'updatedAt']) &&
             data.uid is string &&
             data.status in ['draft', 'completed'] &&
             data.updatedAt is string;
    }

    function isValidSafetyPlan(data) {
      return data.keys().hasAll(['uid', 'updatedAt', 'warningSigns', 'copingStrategies', 'socialContacts', 'professionalSupport', 'safeEnvironment']) &&
             data.uid is string && data.uid.size() <= 128 && data.uid.matches('^[a-zA-Z0-9_\\-]+$') &&
             data.updatedAt is string &&
             data.warningSigns is list && data.warningSigns.size() <= 50 &&
             data.copingStrategies is list && data.copingStrategies.size() <= 50 &&
             data.socialContacts is list && data.socialContacts.size() <= 50 &&
             data.professionalSupport is list && data.professionalSupport.size() <= 50 &&
             data.safeEnvironment is list && data.safeEnvironment.size() <= 50;
    }

    function isValidStopSmokingLog(data) {
      return data.keys().hasAll(['uid', 'intensity', 'nrtUsed', 'timestamp']) &&
             data.uid is string && data.uid.size() <= 128 && data.uid.matches('^[a-zA-Z0-9_\\-]+$') &&
             data.intensity is number && data.intensity >= 0 && data.intensity <= 10 &&
             data.nrtUsed is bool &&
             data.timestamp is string;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'startTime', 'endTime']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.startTime is string &&
             data.endTime is string &&
             (!('description' in data) || data.description is string) &&
             (!('location' in data) || data.location is string) &&
             (!('type' in data) || data.type in ['group', 'appointment', 'workshop']);
    }

    function isValidGroupRoom(data) {
      return data.keys().hasAll(['name', 'type', 'createdBy', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.type in ['Video', 'Audio'] &&
             data.createdBy is string && data.createdBy == request.auth.uid &&
             data.createdAt == request.time;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
    }

    match /safetyPlans/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow create: if isAuthenticated() && isOwner(userId) && isValidSafetyPlan(incoming());
      allow update: if isAuthenticated() && isOwner(userId) && isValidSafetyPlan(incoming()) && incoming().uid == existing().uid;
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isStaff() && isValidEvent(incoming());
    }

    match /stopSmokingLogs/{logId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isStaff());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidStopSmokingLog(request.resource.data);
    }

    match /checkins/{checkinId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isStaff());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    match /welfareChecks/{checkId} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    match /groupRooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidGroupRoom(incoming());
      allow update: if isAuthenticated() && (incoming().diff(existing()).affectedKeys().hasOnly(['participants']) || incoming().createdBy == request.auth.uid);
      allow delete: if isAuthenticated() && existing().createdBy == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /compliance_logs/{logId} {
      allow create: if isAuthenticated();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      allow update, delete: if false;
    }

    match /journals/{entryId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || (isStaff() && resource.data.shared == true));
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidJournalEntry(request.resource.data);
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && isValidJournalEntry(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /breathworkSessions/{sessionId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isStaff());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidBreathworkSession(request.resource.data);
    }

    match /groundingSessions/{sessionId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isStaff());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidGroundingSession(request.resource.data);
    }

    match /cbtRecords/{recordId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isStaff());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidCBTRecord(request.resource.data);
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && isValidCBTRecord(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
