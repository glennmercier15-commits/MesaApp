{
  "entities": {
    "Notification": {
      "title": "Notification",
      "description": "System or user-triggered notification.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string", "enum": ["session", "message", "milestone", "system"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["uid", "title", "body", "type", "timestamp", "read"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Anonymous message in a peer support channel.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "channel": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "senderName", "channel", "timestamp"]
    },
    "JournalEntry": {
      "title": "Journal Entry",
      "description": "Private or shared reflection entry.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID" },
        "text": { "type": "string" },
        "shared": { "type": "boolean", "description": "Whether shared with care team" },
        "createdAt": { "type": "string", "format": "date-time" },
        "wordCount": { "type": "number" }
      },
      "required": ["uid", "text", "shared", "createdAt"]
    },
    "BreathworkSession": {
      "title": "Breathwork Session",
      "description": "Record of a completed breathing exercise.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "technique": { "type": "string", "enum": ["box", "478"] },
        "cycles": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "technique", "cycles", "timestamp"]
    },
    "GroundingSession": {
      "title": "Grounding Session",
      "description": "Record of a completed 5-4-3-2-1 grounding exercise.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "responses": { 
          "type": "object",
          "properties": {
            "see": { "type": "array", "items": { "type": "string" } },
            "touch": { "type": "array", "items": { "type": "string" } },
            "hear": { "type": "array", "items": { "type": "string" } },
            "smell": { "type": "array", "items": { "type": "string" } },
            "taste": { "type": "array", "items": { "type": "string" } }
          }
        }
      },
      "required": ["uid", "timestamp", "responses"]
    },
    "CBTRecord": {
      "title": "CBT Record",
      "description": "Cognitive Behavioral Therapy thought record.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "situation": { "type": "string" },
        "automaticThought": { "type": "string" },
        "emotion": { "type": "string" },
        "evidence": { "type": "string" },
        "balancedThought": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "completed"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "status", "updatedAt"]
    },
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "outreach", "admin"] },
        "location": { "type": "string", "description": "Assigned county or region" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "SafetyPlan": {
      "title": "Safety Plan",
      "description": "Personal safety plan for crisis management.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID" },
        "warningSigns": { "type": "array", "items": { "type": "string" } },
        "copingStrategies": { "type": "array", "items": { "type": "string" } },
        "socialContacts": { "type": "array", "items": { "type": "string" } },
        "professionalSupport": { "type": "array", "items": { "type": "string" } },
        "safeEnvironment": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "updatedAt"]
    },
    "DailyCheckIn": {
      "title": "Daily Check-in",
      "description": "Mood and craving tracking.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "mood": { "type": "number", "description": "1-5 scale" },
        "craving": { "type": "number", "description": "1-5 scale" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "mood", "timestamp"]
    },
    "Event": {
      "title": "Event",
      "description": "Community group activity or appointment.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "type": { "type": "string", "enum": ["group", "appointment", "workshop"] }
      },
      "required": ["title", "startTime", "endTime"]
    },
    "WelfareCheck": {
      "title": "Welfare Check",
      "description": "Location snapshot for outreach staff.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Staff UID" },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["uid", "location", "timestamp"]
    },
    "VirtualGroupRoom": {
      "title": "Virtual Group Room",
      "description": "Active online video/audio peer-support circle.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "time": { "type": "string" },
        "participants": { "type": "number" },
        "type": { "type": "string", "enum": ["Video", "Audio"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "createdBy", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/safetyPlans/{userId}": {
      "schema": "SafetyPlan",
      "description": "User safety plans"
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Community events"
    },
    "/checkins/{checkinId}": {
      "schema": "DailyCheckIn",
      "description": "Daily wellness check-ins"
    },
    "/welfareChecks/{checkId}": {
      "schema": "WelfareCheck",
      "description": "Staff welfare check snapshots"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Peer support chat messages"
    },
    "/journals/{entryId}": {
      "schema": "JournalEntry",
      "description": "Private or shared journal entries"
    },
    "/breathworkSessions/{sessionId}": {
      "schema": "BreathworkSession",
      "description": "Completed breathing exercise sessions"
    },
    "/groundingSessions/{sessionId}": {
      "schema": "GroundingSession",
      "description": "Completed grounding exercise sessions"
    },
    "/cbtRecords/{recordId}": {
      "schema": "CBTRecord",
      "description": "CBT thought records"
    },
    "/groupRooms/{roomId}": {
      "schema": "VirtualGroupRoom",
      "description": "Peer support virtual group rooms"
    }
  }
}
